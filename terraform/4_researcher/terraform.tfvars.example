# File này là mẫu cấu hình cho Part 4.
# Người dùng copy file này thành terraform.tfvars rồi điền giá trị thật của môi trường mình.
# Part 4: Researcher Agent Configuration
# Copy this file to terraform.tfvars and update with your values

# Region deploy của researcher infrastructure.
# Dòng comment cũ còn nhắc App Runner, nhưng implementation hiện tại dùng Lambda Function URL.
aws_region = "us-east-1"

# OpenAI API key dùng cho tracing/runtime tùy cấu hình hiện tại.
openai_api_key = "sk-..."

# Endpoint ingest từ Part 3 để researcher lưu kết quả vào vector store.
alex_api_endpoint = "https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod/ingest"

# API key tương ứng với ingest endpoint ở trên.
alex_api_key = "your-api-key-here"

# Bật/tắt lịch chạy tự động; mặc định nên để false lúc mới setup.
scheduler_enabled = false
