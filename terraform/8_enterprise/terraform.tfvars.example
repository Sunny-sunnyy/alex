# Part 8: Enterprise Monitoring Configuration
# Copy this file to terraform.tfvars and update with your values.
#
# Alex agents use OpenAI through LiteLLM, not AWS Bedrock. Do not add OpenAI
# API keys or model IDs here: CloudWatch has no native OpenAI model metrics.
# Use LangFuse or the OpenAI platform for model, token, latency, and cost data.

# AWS region where the Alex Lambda functions and SageMaker embedding endpoint
# are deployed. The current project deployment uses ap-southeast-1.
aws_region = "ap-southeast-1"
